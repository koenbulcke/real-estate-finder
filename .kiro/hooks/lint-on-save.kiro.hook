{
  "enabled": true,
  "name": "Lint on Save",
  "description": "Runs ESLint on any JSX file when it's saved",
  "version": "1",
  "when": {
    "type": "fileEdited",
    "patterns": [
      "**/*.jsx",
      "**/*.js"
    ]
  },
  "then": {
    "type": "runCommand",
    "command": "npx eslint --fix ${file}"
  }
}